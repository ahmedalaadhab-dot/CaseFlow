# --- Database ---
DATABASE_URL="postgresql://caseflow:caseflow@localhost:5432/caseflow?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# --- Auth ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Storage ---
# "local" for dev (writes to STORAGE_LOCAL_PATH, served from /uploads).
# "s3" for production — works with real AWS S3 or any S3-compatible
# provider (e.g. Cloudflare R2: set S3_ENDPOINT to the account's R2
# endpoint and S3_REGION="auto"). Documents are private; the API hands out
# short-lived signed URLs rather than exposing a public bucket.
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./uploads"
MAX_UPLOAD_MB=25

# Required when STORAGE_DRIVER=s3:
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=              # leave unset for real AWS S3
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
